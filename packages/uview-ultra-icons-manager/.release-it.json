{
  "git": {
    "commitMessage": "chore(@uview-ultra/icons-manager): release v${version}",
    "tagName": "icons-manager-v${version}"
  },
  "npm": {
    "publish": true
  },
  "hooks": {
    "before:release": "npm run build"
  },
  "plugins": {
    "@release-it/conventional-changelog": {
      "preset": "angular",
      "infile": "CHANGELOG.md"
    }
  }
}
