{
  "git": {
    "commitMessage": "chore(uview-ultra): release v${version}",
    "tagName": "uview-ultra-v${version}"
  },
  "npm": {
    "publish": true
  },
  "hooks": {
    "before:release": "npm run build"
  },
  "plugins": {
    "@release-it/conventional-changelog": {
      "preset": "angular",
      "infile": "CHANGELOG.md"
    }
  }
}
